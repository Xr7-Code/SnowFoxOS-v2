{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "exclusive": true,

    "modules-left": [
        "custom/menu",
        "sway/workspaces"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "battery",
        "bluetooth",
        "network",
        "pulseaudio",
        "tray"
    ],

    "custom/menu": {
        "format": "<img src='/usr/share/icons/hicolor/24x24/apps/snowfox.png' alt='menu'/>",
        "tooltip": false,
        "return-type": "",
        "on-click": "wofi --show drun --prompt 'Suchen...'"
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{name}",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%H:%M  %a %d.%m.%Y}",
        "tooltip-format": "<big>{:%A, %d. %B %Y}</big>",
        "on-click": "toggle"
    },

    "cpu": {
        "interval": 2,
        "format": " {usage}%",
        "tooltip": false,
        "on-click": "kitty --title btop btop"
    },

    "memory": {
        "interval": 2,
        "format": " {percentage}%",
        "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB",
        "on-click": "kitty --title btop btop"
    },

    "temperature": {
        "interval": 4,
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°",
        "format-icons": ["", "", ""],
        "tooltip": false
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo} — {power:.1f}W"
    },

    "bluetooth": {
        "format": "",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\n{num_connections} verbunden",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} verbunden\n\n{device_enumerate}",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " Ethernet",
        "format-disconnected": " Getrennt",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ipaddr}",
        "on-click": "kitty --title nmtui nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " stumm",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
        "tooltip": false
    },

    "tray": {
        "icon-size": 18,
        "spacing": 8
    }
}
