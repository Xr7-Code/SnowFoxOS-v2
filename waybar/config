{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "exclusive": true,

    "modules-left": [
        "custom/menu",
        "sway/workspaces",
        "sway/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "backlight",
        "battery",
        "bluetooth",
        "network",
        "pulseaudio",
        "tray"
    ],

    "custom/menu": {
        "format": "  ",
        "tooltip": false,
        "on-click": "wofi --show drun --prompt 'Suchen...'"
    },

    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": false,
        "format": "{name}",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "sway/window": {
        "max-length": 50,
        "tooltip": false
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%H:%M  %a %d.%m.%Y}",
        "tooltip-format": "<big>{:%A, %d. %B %Y}</big>",
        "on-click": "toggle"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo} — {power:.1f}W"
    },

    "bluetooth": {
        "format": "",
        "format-connected": " {device_alias}",
        "format-connected-battery": " {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\n{num_connections} verbunden",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} verbunden\n\n{device_enumerate}",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " Ethernet",
        "format-disconnected": "睊 Getrennt",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
        "tooltip-format-ethernet": "{ipaddr}",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": " stumm",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
        "tooltip": false
    },

    "tray": {
        "icon-size": 18,
        "spacing": 8
    }
}
