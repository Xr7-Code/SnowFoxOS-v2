    update)   cmd_update ;;
    gpu)      cmd_gpu ;;
    audit)    cmd_audit ;;
    airmode)  cmd_airmode "$2" ;;
    kill)     cmd_kill "$2" ;;
    download) cmd_download "$2" ;;
